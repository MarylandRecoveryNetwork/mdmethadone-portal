# ─────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in your real values.
# Get these from Supabase → Settings → API.
# ─────────────────────────────────────────────────────────────

# Project URL (looks like https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon / publishable key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY

# The public site URL
NEXT_PUBLIC_SITE_URL=https://www.mdmethadone.help

# Service role key — SERVER ONLY. Never commit. Never expose in client code.
# Supabase → Settings → API → service_role (click "reveal")
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
